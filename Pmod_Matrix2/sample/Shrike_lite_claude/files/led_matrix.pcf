# =============================================================================
# led_matrix.pcf  -  Shrike lite / SLG47910V ピン制約ファイル
# Go Configure Software Hub (GCSH) / nextpnr-himbaechel 向け
# =============================================================================
#
# 信号名       : FPGA物理ピン  : ボード信号
# -------------|--------------|-----------------------------
# clk          : OSC_CLK      : 内蔵50MHz発振器 (F18相当)
# sr_dat_red   : F18 / GPIO12 : COL_Red  74LS595 SER入力
# sr_dat_grn   : F17 / GPIO15 : COL_Green 74LS595 SER入力
# sr_dat_row   : F18 / GPIO14 : ROW 74LS595 SER入力
# sr_clk       : 追加GPIO     : 595共通SHCP (シフトクロック)
# sr_lat       : 追加GPIO     : 595共通STCP (ストレージラッチ)
#
# ※ SLG47910Vの内蔵OSCはGCSH上でOSC_CLKポートとして接続
# ※ GPIO12=F18, GPIO14=F18(?), GPIO15=F17 はボード回路図要確認
#   (DeepWiki資料より: GPIO14→FPGA Pin18, GPIO15→FPGA Pin17)
#   GPIO12はRP2040側のFPGA電源制御ピンのため、実際の外部GPIOは
#   ボードのヘッダピンから確認してください。
# =============================================================================

# クロック (内蔵発振器)
set_io clk OSC_CLK

# --- データ出力 ---
# COL_Red  : GPIO12相当のFPGAピン → ヘッダ J1/J2 上の対応ピンを使用
# ボードのピンアウト図でFPGA側GPIOを確認して変更してください
set_io sr_dat_red  IOB_12    # FPGA GPIO / COL_Red  (GPIO12 header)
set_io sr_dat_grn  IOB_15    # FPGA GPIO / COL_Green(GPIO15 header)
set_io sr_dat_row  IOB_14    # FPGA GPIO / ROW      (GPIO14 header)

# --- 74LS595 共通制御 (空きFPGA GPIOを割り当て) ---
set_io sr_clk      IOB_8     # 595 SHCP (シフトクロック) ← 空きピン
set_io sr_lat      IOB_9     # 595 STCP (ストレージラッチ)← 空きピン
