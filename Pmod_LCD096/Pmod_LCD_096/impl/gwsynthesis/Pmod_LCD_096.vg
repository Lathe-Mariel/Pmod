module gw_gao (
  tms_pad_i,
  tck_pad_i,
  tdi_pad_i,
  clk_d,
  lcd_cs_d,
  lcd_mosi_d,
  lcd_dc_2,
  clk_div,
  lcd_rst_d,
  u_ctrl_0_2,
  u_ctrl_1_2,
  tx_data_15_3,
  tx_data_10_3,
  tx_data_7_3,
  tx_data_6_3,
  tx_data_5_3,
  tx_data_4_3,
  tx_data_3_3,
  tx_data_2_3,
  tx_data_1_3,
  tx_data_0_3,
  rst_n_d,
  tdo_pad_o
)
;
input tms_pad_i;
input tck_pad_i;
input tdi_pad_i;
input clk_d;
input lcd_cs_d;
input lcd_mosi_d;
input lcd_dc_2;
input clk_div;
input lcd_rst_d;
input u_ctrl_0_2;
input u_ctrl_1_2;
input tx_data_15_3;
input tx_data_10_3;
input tx_data_7_3;
input tx_data_6_3;
input tx_data_5_3;
input tx_data_4_3;
input tx_data_3_3;
input tx_data_2_3;
input tx_data_1_3;
input tx_data_0_3;
input rst_n_d;
output tdo_pad_o;
wire tms_i_c;
wire tck_i_c;
wire tdi_i_c;
wire tdo_o_c;
wire gao_jtag_tdi;
wire gao_jtag_reset;
wire run_test_idle_er1;
wire run_test_idle_er2;
wire shift_dr_capture_dr;
wire pause_dr;
wire enable_er1;
wire enable_er2;
wire tdo_er1;
wire n12_6;
wire [5:0] control0;
wire [4:2] control0_0;
wire [3:0] module_id_reg;
wire [7:7] control0_1;
wire VCC;
wire GND;
  IBUF tms_ibuf (
    .O(tms_i_c),
    .I(tms_pad_i) 
);
  IBUF tck_ibuf (
    .O(tck_i_c),
    .I(tck_pad_i) 
);
  IBUF tdi_ibuf (
    .O(tdi_i_c),
    .I(tdi_pad_i) 
);
  OBUF tdo_obuf (
    .O(tdo_pad_o),
    .I(tdo_o_c) 
);
//black box: GW_JTAG u_gw_jtag
  GW_JTAG u_gw_jtag (
    .tck_pad_i(tck_i_c),
    .tms_pad_i(tms_i_c),
    .tdi_pad_i(tdi_i_c),
    .tdo_er1_i(tdo_er1),
    .tdo_er2_i(GND),
    .tdo_pad_o(tdo_o_c),
    .tck_o(control0[0]),
    .tdi_o(gao_jtag_tdi),
    .test_logic_reset_o(gao_jtag_reset),
    .run_test_idle_er1_o(run_test_idle_er1),
    .run_test_idle_er2_o(run_test_idle_er2),
    .shift_dr_capture_dr_o(shift_dr_capture_dr),
    .pause_dr_o(pause_dr),
    .update_dr_o(control0[5]),
    .enable_er1_o(enable_er1),
    .enable_er2_o(enable_er2) 
);
  gw_con_top u_icon_top (
    .shift_dr_capture_dr(shift_dr_capture_dr),
    .enable_er1(enable_er1),
    .gao_jtag_tdi(gao_jtag_tdi),
    .gao_jtag_reset(gao_jtag_reset),
    .control0(control0_1[7]),
    .control0_0_1(control0[0]),
    .control0_5(control0[5]),
    .tdo_er1(tdo_er1),
    .n12_6(n12_6),
    .control0_2_3(control0_0[2]),
    .control0_4(control0_0[4]),
    .module_id_reg(module_id_reg[3:0])
);
  ao_top_0 u_la0_top (
    .n12_6(n12_6),
    .clk_d(clk_d),
    .shift_dr_capture_dr(shift_dr_capture_dr),
    .lcd_cs_d(lcd_cs_d),
    .lcd_mosi_d(lcd_mosi_d),
    .lcd_dc_2(lcd_dc_2),
    .clk_div(clk_div),
    .lcd_rst_d(lcd_rst_d),
    .u_ctrl_0_2(u_ctrl_0_2),
    .u_ctrl_1_2(u_ctrl_1_2),
    .tx_data_15_3(tx_data_15_3),
    .tx_data_10_3(tx_data_10_3),
    .tx_data_7_3(tx_data_7_3),
    .tx_data_6_3(tx_data_6_3),
    .tx_data_5_3(tx_data_5_3),
    .tx_data_4_3(tx_data_4_3),
    .tx_data_3_3(tx_data_3_3),
    .tx_data_2_3(tx_data_2_3),
    .tx_data_1_3(tx_data_1_3),
    .tx_data_0_3(tx_data_0_3),
    .rst_n_d(rst_n_d),
    .control0_2(control0_0[2]),
    .control0_4(control0_0[4]),
    .control0_0(control0[0]),
    .control0_5_6(control0[5]),
    .module_id_reg(module_id_reg[3:0]),
    .control0_7(control0_1[7])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* gw_gao */
module top (
  clk,
  rst_n,
  lcd_cs,
  lcd_mosi,
  lcd_dc,
  lcd_clk,
  lcd_rst,
  tms_pad_i,
  tck_pad_i,
  tdi_pad_i,
  tdo_pad_o
)
;
input clk;
input rst_n;
output lcd_cs;
output lcd_mosi;
output lcd_dc;
output lcd_clk;
output lcd_rst;
input tms_pad_i;
input tck_pad_i;
input tdi_pad_i;
output tdo_pad_o;
wire clk_d;
wire rst_n_d;
wire lcd_clk_d;
wire clk_div;
wire n6_6;
wire n7_6;
wire lcd_mosi_d;
wire u_ctrl_0_2;
wire lcd_rst_d;
wire u_ctrl_1_2;
wire lcd_cs_d;
wire lcd_dc_2;
wire tx_data_15_3;
wire tx_data_10_3;
wire tx_data_7_3;
wire tx_data_6_3;
wire tx_data_5_3;
wire tx_data_4_3;
wire tx_data_3_3;
wire tx_data_2_3;
wire tx_data_1_3;
wire tx_data_0_3;
wire VCC;
wire GND;
  IBUF clk_ibuf (
    .O(clk_d),
    .I(clk) 
);
  IBUF rst_n_ibuf (
    .O(rst_n_d),
    .I(rst_n) 
);
  OBUF lcd_cs_obuf (
    .O(lcd_cs),
    .I(lcd_cs_d) 
);
  OBUF lcd_mosi_obuf (
    .O(lcd_mosi),
    .I(lcd_mosi_d) 
);
  OBUF lcd_dc_obuf (
    .O(lcd_dc),
    .I(lcd_dc_2) 
);
  OBUF lcd_clk_obuf (
    .O(lcd_clk),
    .I(lcd_clk_d) 
);
  OBUF lcd_rst_obuf (
    .O(lcd_rst),
    .I(lcd_rst_d) 
);
  LUT2 lcd_clk_d_s (
    .F(lcd_clk_d),
    .I0(clk_div),
    .I1(lcd_cs_d) 
);
defparam lcd_clk_d_s.INIT=4'hE;
  DFFCE clk_div_s0 (
    .Q(clk_div),
    .D(n7_6),
    .CLK(clk_d),
    .CLEAR(n6_6),
    .CE(VCC) 
);
  INV n6_s2 (
    .O(n6_6),
    .I(rst_n_d) 
);
  INV n7_s2 (
    .O(n7_6),
    .I(clk_div) 
);
  lcd_controller u_ctrl (
    .clk_d(clk_d),
    .n6_6(n6_6),
    .clk_div(clk_div),
    .lcd_mosi_d(lcd_mosi_d),
    .u_ctrl_0_2(u_ctrl_0_2),
    .lcd_rst_d(lcd_rst_d),
    .u_ctrl_1_2(u_ctrl_1_2),
    .lcd_cs_d(lcd_cs_d),
    .lcd_dc_2(lcd_dc_2),
    .tx_data_15_3(tx_data_15_3),
    .tx_data_10_3(tx_data_10_3),
    .tx_data_7_3(tx_data_7_3),
    .tx_data_6_3(tx_data_6_3),
    .tx_data_5_3(tx_data_5_3),
    .tx_data_4_3(tx_data_4_3),
    .tx_data_3_3(tx_data_3_3),
    .tx_data_2_3(tx_data_2_3),
    .tx_data_1_3(tx_data_1_3),
    .tx_data_0_3(tx_data_0_3)
);
  gw_gao gw_gao_inst_0 (
    .tms_pad_i(tms_pad_i),
    .tck_pad_i(tck_pad_i),
    .tdi_pad_i(tdi_pad_i),
    .clk_d(clk_d),
    .lcd_cs_d(lcd_cs_d),
    .lcd_mosi_d(lcd_mosi_d),
    .lcd_dc_2(lcd_dc_2),
    .clk_div(clk_div),
    .lcd_rst_d(lcd_rst_d),
    .u_ctrl_0_2(u_ctrl_0_2),
    .u_ctrl_1_2(u_ctrl_1_2),
    .tx_data_15_3(tx_data_15_3),
    .tx_data_10_3(tx_data_10_3),
    .tx_data_7_3(tx_data_7_3),
    .tx_data_6_3(tx_data_6_3),
    .tx_data_5_3(tx_data_5_3),
    .tx_data_4_3(tx_data_4_3),
    .tx_data_3_3(tx_data_3_3),
    .tx_data_2_3(tx_data_2_3),
    .tx_data_1_3(tx_data_1_3),
    .tx_data_0_3(tx_data_0_3),
    .rst_n_d(rst_n_d),
    .tdo_pad_o(tdo_pad_o)
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* top */
